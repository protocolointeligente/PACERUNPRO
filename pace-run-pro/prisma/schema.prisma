// Pace Run Pro — modelo de dados
// PostgreSQL + Prisma. Reflete as entidades centrais do produto:
// gestão de atletas/treinadores, prescrição (corrida e força),
// periodização, testes de performance, check-ins, integrações e cobrança.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────────────────────────────────────────
// Identidade & contas
// ────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  COACH
  ATHLETE
}

enum Sex {
  MASCULINO
  FEMININO
  OUTRO
}

enum SportType {
  RUN
  BIKE
  SWIM
  STRENGTH
  MOBILITY
  TRIATHLON
  BRICK
}

enum Goal {
  // Corrida
  CINCO_KM
  DEZ_KM
  VINTE_E_UM_KM
  QUARENTA_E_DOIS_KM
  ULTRAMARATONA
  EMAGRECIMENTO
  PERFORMANCE
  RETORNO_AS_CORRIDAS
  // Ciclismo
  GRAN_FONDO
  CICLISMO_PERFORMANCE
  // Natação
  NATACAO_PERFORMANCE
  // Triathlon
  SPRINT_TRIATHLON
  OLIMPICO
  MEIO_IRONMAN
  IRONMAN
  AQUATLON
  DUATLON
}

enum ExperienceLevel {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
  PRO
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String
  avatarUrl     String?
  bannerUrl     String?
  image         String?
  role          UserRole @default(ATHLETE)
  phone         String?
  city          String?
  state         String?
  emailVerified   DateTime?
  tosAcceptedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  athlete       Athlete?
  coach         Coach?
  notifications Notification[]
  subscriptions Subscription[]
  payments      Payment[]
  devices       ConnectedDevice[]
  feedPosts     FeedPost[]
  feedComments  FeedComment[]
  feedLikes     FeedLike[]
  accounts      Account[]
  sessions      Session[]
  vouchersCreated     Voucher[] @relation("VouchersCreated")
  billingSettings     BillingSettings?
  workoutLogComments  WorkoutLogComment[]
  pushSubscriptions   PushSubscription[]
  messagesSent        Message[]          @relation("MessagesSent")
  consentRecords      DataConsentRecord[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ────────────────────────────────────────────────────────────────────────────
// Atletas & treinadores
// ────────────────────────────────────────────────────────────────────────────

model Athlete {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachId           String?
  coach             Coach?          @relation(fields: [coachId], references: [id])

  birthDate         DateTime?
  sex               Sex?
  heightCm          Float?
  weightKg          Float?
  goal              Goal?
  level             ExperienceLevel @default(INICIANTE)
  weeklyAvailability Int?           // dias por semana
  availableMinutes   Int?           // minutos por sessão
  injuryHistory      String?
  raceDate           DateTime?
  recentBestTime     String?
  status             String          @default("ativo") // ativo | risco | inativo
  adherenceRate      Float           @default(0) // 0–1
  recoveryScore      Float           @default(0) // 0–1

  parqAccepted       Boolean         @default(false)
  parqAcceptedAt     DateTime?

  metrics            Metric[]
  checkins           CheckIn[]
  performanceTests   PerformanceTest[]
  trainingPlans      TrainingPlan[]
  workoutLogs        WorkoutLog[]
  races              Race[]
  achievements       Achievement[]
  teamMemberships    TeamMember[]
  loadParams         AthleteLoadParams?
  planPurchases      PlanPurchase[]
  recoveryLogs       RecoveryLog[]
  questionnaires     Questionnaire[]
  physicalAssessments PhysicalAssessment[]
  marketplaceOrders  MarketplaceOrder[]
  marketplaceReviews MarketplaceReview[]
  lessonProgress     CourseLessonProgress[]
  eventRegistrations EventRegistration[]
  challengeParticipations ChallengeParticipant[]
  appointments       Appointment[]

  shoes              Shoe[]
  sportProfiles      AthleteSportProfile[]
  dailyLoads         DailyLoad[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([coachId])
  @@map("athletes")
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

model Coach {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential      String?   // ex.: CREF 014626-G/MG
  bio             String?
  publicBio       String?   // texto exibido na página pública da assessoria
  specialties     String[]
  slug            String?   @unique  // ex.: "ricardo-pace" → /p/ricardo-pace
  logoUrl         String?
  whatsapp        String?
  onboardingDone  String[]  @default([])  // completed step ids: ["invite","workout","plan"]

  // KYC básico
  kycStatus       KycStatus @default(PENDING)
  kycDocumentUrl  String?
  kycSubmittedAt  DateTime?
  kycReviewedAt   DateTime?
  kycNotes        String?

  plans             CoachPlan[]
  athletes          Athlete[]
  teams             Team[]
  trainingPlans     TrainingPlan[]
  exercises         Exercise[]
  strengthTemplates CoachStrengthTemplate[]
  runTemplates      CoachRunTemplate[]
  leads             Lead[]
  expenses          Expense[]
  zoneModels        CoachZoneModel[]
  planProducts      PlanProduct[]
  sharedTemplates   SharedWorkoutTemplate[]
  athleteInvites    AthleteInvite[]
  marketplaceStore  MarketplaceStore?
  marketplaceProducts MarketplaceProduct[]
  marketplaceCommissions MarketplaceCommission[]
  marketplacePayouts MarketplacePayout[]
  marketplaceCoupons MarketplaceCoupon[]
  challenges        Challenge[]
  appointments      Appointment[]
  coachAvailability CoachAvailability[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("coaches")
}

model Team {
  id        String       @id @default(cuid())
  name      String
  coachId   String
  coach     Coach        @relation(fields: [coachId], references: [id])
  members   TeamMember[]
  createdAt DateTime     @default(now())

  @@index([coachId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([teamId, athleteId])
  @@map("team_members")
}

// ────────────────────────────────────────────────────────────────────────────
// Periodização & planos de treino
// ────────────────────────────────────────────────────────────────────────────

enum CyclePhase {
  BASE
  CONSTRUCAO
  ESPECIFICO
  POLIMENTO
  COMPETICAO
  RECUPERACAO
}

model TrainingPlan {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coachId     String?
  coach       Coach?   @relation(fields: [coachId], references: [id])

  purchaseId  String?  @unique  // link to the PlanPurchase that originated this plan

  name        String
  goal        Goal
  raceDate    DateTime?
  macrocycle  String?  // nome/descrição do macrociclo
  phase       CyclePhase @default(BASE)
  startDate   DateTime
  endDate     DateTime

  weeks       TrainingWeek[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("training_plans")
}

model TrainingWeek {
  id           String     @id @default(cuid())
  planId       String
  plan         TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  weekNumber   Int
  mesocycle    String?
  phase        CyclePhase @default(BASE)
  startDate    DateTime
  endDate      DateTime
  targetLoad   Float?     // carga semanal planejada (TRIMP/UA)
  targetVolumeKm Float?
  released     Boolean    @default(false) // liberação semanal pelo treinador
  releasedAt   DateTime?

  workouts     Workout[]

  @@unique([planId, weekNumber])
  @@index([planId, weekNumber])
  @@map("training_weeks")
}

// ────────────────────────────────────────────────────────────────────────────
// Treinos
// ────────────────────────────────────────────────────────────────────────────

enum WorkoutType {
  // ── Corrida ────────────────────────────────────────────
  RODAGEM_LEVE
  INTERVALADO_CURTO
  INTERVALADO_LONGO
  TEMPO_RUN
  FARTLEK
  PROGRESSIVO
  LONGAO
  REGENERATIVO
  SUBIDA
  TECNICA
  PROVA
  // ── Ciclismo ───────────────────────────────────────────
  ENDURANCE_BIKE
  RECOVERY_BIKE
  TEMPO_BIKE
  SWEET_SPOT
  THRESHOLD_BIKE
  VO2MAX_BIKE
  ANAEROBIC_BIKE
  SPRINT_BIKE
  LONG_RIDE
  // ── Natação ────────────────────────────────────────────
  TECNICA_NATACAO
  ENDURANCE_NATACAO
  INTERVALADO_NATACAO
  LIMIAR_NATACAO
  SPRINT_NATACAO
  RECUPERACAO_NATACAO
  AGUAS_ABERTAS
  // ── Triathlon / Brick ──────────────────────────────────
  BRICK_BIKE_RUN
  BRICK_SWIM_BIKE
  TRANSICAO
  SIMULADO_TRIATHLON
  TREINO_COMBINADO
  // ── Genérico ───────────────────────────────────────────
  FORCA
  FUNCIONAL
  MOBILIDADE
  RECUPERACAO
}

enum WorkoutStatus {
  AGENDADO
  LIBERADO
  CONCLUIDO
  PERDIDO
  AJUSTADO
}

model Workout {
  id            String        @id @default(cuid())
  weekId        String
  week          TrainingWeek  @relation(fields: [weekId], references: [id], onDelete: Cascade)

  date          DateTime
  type          WorkoutType
  sport         SportType?    // RUN | BIKE | SWIM | STRENGTH | MOBILITY | TRIATHLON | BRICK
  title         String
  status        WorkoutStatus @default(AGENDADO)

  objective     String?
  warmup        String?
  mainSet       String?
  cooldown      String?
  notes         String?

  structured    Boolean  @default(false)  // treino com blocos estruturados
  blocks        Json?                     // WorkoutBlock[] — ver lib/workout-blocks.ts

  // ── Alvos universais ──────────────────────────────────
  targetHrZone       String?
  targetRpe          Int?
  targetDistanceKm   Float?
  targetDurationMin  Int?
  targetTss          Int?     // TSS alvo prescrito
  plannedLoad        Float?   // carga planejada (sRPE estimado)

  // ── Corrida ───────────────────────────────────────────
  targetPaceSecPerKm Int?

  // ── Ciclismo ──────────────────────────────────────────
  targetPowerWatts   Int?     // potência alvo (W)
  targetPowerPctFtp  Int?     // % do FTP alvo (ex: 95 = 95% FTP)
  targetCadence      Int?     // cadência alvo (rpm)

  // ── Natação ───────────────────────────────────────────
  targetPacePer100m  Int?     // pace alvo em seg/100m
  targetStrokeRate   Int?     // braçadas por minuto alvo
  targetSwolf        Int?     // SWOLF alvo

  videoUrl      String?
  imageUrl      String?

  strengthWorkout StrengthWorkout?
  logs            WorkoutLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([weekId, date])
  @@map("workouts")
}

model WorkoutLog {
  id           String   @id @default(cuid())
  workoutId    String?
  workout      Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  athleteId    String
  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  // Source tracking
  source              String    @default("manual") // manual | strava | garmin | polar | coros | apple | google_fit | suunto
  stravaActivityId    String?   @unique
  externalActivityId  String?   // provider-specific activity ID (used with source for dedup)

  // ── Modalidade ────────────────────────────────────────
  sport               SportType? // RUN | BIKE | SWIM | STRENGTH | MOBILITY | TRIATHLON | BRICK

  // ── Dados de execução universais ──────────────────────
  startedAt    DateTime?
  finishedAt   DateTime?
  distanceKm   Float?
  durationSec  Int?
  avgHr        Int?
  maxHr        Int?
  elevationGainM Float?
  calories     Int?
  gpsTrack     Json?
  splits       Json?
  rpe          Int?
  feeling      String?

  // ── Carga calculada ───────────────────────────────────
  tss          Float?   // Training Stress Score real
  actualLoad   Float?   // sRPE load = durationMin × RPE

  // ── Corrida ───────────────────────────────────────────
  avgPaceSecPerKm Int?
  cadence         Int?

  // ── Ciclismo ──────────────────────────────────────────
  avgWatts          Int?
  normalizedPower   Int?   // NP
  intensityFactor   Float? // IF = NP / FTP
  tssFromPower      Float? // TSS calculado por potência

  // ── Natação ───────────────────────────────────────────
  poolLengthM       Int?   // 25 | 50
  swimStroke        String? // freestyle | backstroke | breaststroke | butterfly | medley
  swolf             Int?   // SWOLF = tempo/piscina + braçadas
  strokeRate        Int?   // braçadas por minuto
  avgPacePer100m    Int?   // pace médio em seg/100m

  // ── Feedback ──────────────────────────────────────────
  coachFeedback    String?
  athleteFeedback  String?

  comments     WorkoutLogComment[]

  createdAt    DateTime @default(now())

  @@index([athleteId, startedAt])
  @@index([athleteId, sport])
  @@index([workoutId])
  @@index([source, externalActivityId])
  @@map("workout_logs")
}

model WorkoutLogComment {
  id           String     @id @default(cuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  text         String

  createdAt    DateTime   @default(now())

  @@index([workoutLogId])
  @@map("workout_log_comments")
}

// ────────────────────────────────────────────────────────────────────────────
// Força & funcional
// ────────────────────────────────────────────────────────────────────────────

enum StrengthSplit {
  AB
  ABC
  ABCD
  ABCDE
  FULL_BODY
  UPPER_LOWER
  PERSONALIZADA
}

model StrengthWorkout {
  id        String        @id @default(cuid())
  workoutId String        @unique
  workout   Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  split     StrengthSplit @default(FULL_BODY)
  label     String?       // ex.: "Treino A — Inferior + Core"
  blocks    StrengthBlock[]

  @@map("strength_workouts")
}

model StrengthBlock {
  id                String          @id @default(cuid())
  strengthWorkoutId String
  strengthWorkout   StrengthWorkout @relation(fields: [strengthWorkoutId], references: [id], onDelete: Cascade)
  exerciseId        String
  exercise          Exercise        @relation(fields: [exerciseId], references: [id])

  order             Int
  sets              Int
  reps              String  // ex.: "10-12" ou "30s"
  load              String? // ex.: "60% 1RM" ou "peso corporal"
  restSec           Int?
  rpe               Int?
  notes             String?

  @@map("strength_blocks")
}

enum ExerciseCategory {
  FORCA
  HIPERTROFIA
  CORE
  MOBILIDADE
  PLIOMETRIA
  PREVENCAO
  GLUTEOS
  PANTURRILHAS
  JOELHO
  QUADRIL
  TORNOZELO
}

model Exercise {
  id            String           @id @default(cuid())
  coachId       String?
  coach         Coach?           @relation(fields: [coachId], references: [id])

  name          String
  category      ExerciseCategory
  description   String?
  execution     String?          // execução correta
  commonMistakes String?         // erros comuns
  musclesWorked String[]
  imageUrl      String?

  videos        ExerciseVideo[]
  blocks        StrengthBlock[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("exercises")
}

model ExerciseVideo {
  id         String   @id @default(cuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  url        String
  title      String?
  durationSec Int?

  @@map("exercise_videos")
}

// ────────────────────────────────────────────────────────────────────────────
// Testes de performance
// ────────────────────────────────────────────────────────────────────────────

enum TestType {
  // ── Corrida ────────────────────────────────────────────
  COOPER
  CINCO_MINUTOS
  TRES_KM
  DOIS_MIL_E_QUATROCENTOS_M
  VAM
  RAST
  LIMIAR
  // ── Ciclismo ───────────────────────────────────────────
  FTP_20MIN
  FTP_RAMP
  CRITICAL_POWER_5MIN
  CRITICAL_POWER_20MIN
  FC_LIMIAR_BIKE
  // ── Natação ────────────────────────────────────────────
  CSS_400_200
  CSS_1000M
  SWIM_30MIN
  PACE_CRITICO_NATACAO
  TECNICA_NATACAO
}

model PerformanceTest {
  id          String    @id @default(cuid())
  athleteId   String
  athlete     Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  type        TestType
  sport       SportType? // modalidade do teste
  date        DateTime
  distanceM   Float?
  durationSec Int?
  avgHr       Int?
  maxHr       Int?

  // ── Corrida ───────────────────────────────────────────
  vo2max                Float?
  vamKmh                Float?
  thresholdPaceSecPerKm Int?

  // ── Ciclismo ──────────────────────────────────────────
  avgWatts              Int?    // potência média do teste
  ftpWatts              Int?    // FTP calculado
  criticalPowerWatts    Int?    // CP calculado

  // ── Natação ───────────────────────────────────────────
  cssPacePer100m        Int?    // CSS em seg/100m
  time400mSec           Int?    // tempo 400m (CSS test)
  time200mSec           Int?    // tempo 200m (CSS test)

  notes       String?

  createdAt   DateTime @default(now())

  @@index([athleteId, date])
  @@index([athleteId, sport])
  @@map("performance_tests")
}

// ────────────────────────────────────────────────────────────────────────────
// Check-ins & métricas
// ────────────────────────────────────────────────────────────────────────────

model CheckIn {
  id         String   @id @default(cuid())
  athleteId  String
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  date       DateTime @default(now())
  rpe        Int?     // 0-10
  pain       Int?     // 0-10
  sleep      Int?     // 0-10
  fatigue    Int?     // 0-10
  mood       Int?     // 0-10
  notes      String?

  flagged    Boolean  @default(false)
  flagReason String?

  // Hooper Index — estresse percebido (0-10); combina com sleep+fatigue+mood = score composto
  stress     Int?

  createdAt  DateTime @default(now())

  @@index([athleteId, date])
  @@map("checkins")
}

model Metric {
  id        String   @id @default(cuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  date      DateTime @default(now())
  weightKg  Float?
  bodyFatPct Float?
  restingHr Int?
  hrv       Float?
  vo2max    Float?
  notes     String?

  @@index([athleteId, date])
  @@map("metrics")
}

// ────────────────────────────────────────────────────────────────────────────
// Provas, conquistas, comunidade
// ────────────────────────────────────────────────────────────────────────────

model Race {
  id         String   @id @default(cuid())
  athleteId  String
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  name       String
  date       DateTime
  distanceKm Float
  goalTime   String?
  resultTime String?
  location   String?

  @@index([athleteId, date])
  @@map("races")
}

model Achievement {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  title       String
  description String?
  icon        String?
  earnedAt    DateTime @default(now())

  @@index([athleteId])
  @@map("achievements")
}

model FeedPost {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content   String
  imageUrl  String?
  workoutSummary Json?

  comments  FeedComment[]
  likes     FeedLike[]

  createdAt DateTime @default(now())

  @@index([authorId, createdAt])
  @@map("feed_posts")
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([authorId])
  @@map("feed_comments")
}

model FeedLike {
  id       String   @id @default(cuid())
  postId   String
  post     FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("feed_likes")
}

// ────────────────────────────────────────────────────────────────────────────
// Notificações, dispositivos, assinaturas e pagamentos
// ────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("notifications")
}

model AthleteInvite {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  email     String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@map("athlete_invites")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

model PhysicalAssessment {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coachId     String?
  assessedAt  DateTime @default(now())

  // Body composition
  weightKg    Float?
  bodyFatPct  Float?
  muscleMassKg Float?
  bmi         Float?

  // Perimetry (cm)
  neckCm      Float?
  chestCm     Float?
  waistCm     Float?
  hipCm       Float?
  thighCm     Float?
  calfCm      Float?
  armCm       Float?
  forearmCm   Float?

  // Performance
  vo2max      Float?
  restingHr   Int?
  hrv         Float?
  flexibilityScore Float?

  // Photos and consent
  photoUrls   String[]
  lgpdConsent Boolean  @default(false)
