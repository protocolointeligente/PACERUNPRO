// Pace Run Pro — modelo de dados
// PostgreSQL + Prisma. Reflete as entidades centrais do produto:
// gestão de atletas/treinadores, prescrição (corrida e força),
// periodização, testes de performance, check-ins, integrações e cobrança.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────────────────────────────────────────
// Identidade & contas
// ────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  COACH
  ATHLETE
}

enum Sex {
  MASCULINO
  FEMININO
  OUTRO
}

enum Goal {
  CINCO_KM
  DEZ_KM
  VINTE_E_UM_KM
  QUARENTA_E_DOIS_KM
  ULTRAMARATONA
  EMAGRECIMENTO
  PERFORMANCE
  RETORNO_AS_CORRIDAS
}

enum ExperienceLevel {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
  PRO
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String
  avatarUrl     String?
  bannerUrl     String?
  image         String?
  role          UserRole @default(ATHLETE)
  phone         String?
  city          String?
  state         String?
  emailVerified   DateTime?
  tosAcceptedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  athlete       Athlete?
  coach         Coach?
  notifications Notification[]
  subscriptions Subscription[]
  payments      Payment[]
  devices       ConnectedDevice[]
  feedPosts     FeedPost[]
  feedComments  FeedComment[]
  feedLikes     FeedLike[]
  accounts      Account[]
  sessions      Session[]
  vouchersCreated     Voucher[] @relation("VouchersCreated")
  billingSettings     BillingSettings?
  workoutLogComments  WorkoutLogComment[]
  pushSubscriptions   PushSubscription[]
  messagesSent        Message[]          @relation("MessagesSent")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ────────────────────────────────────────────────────────────────────────────
// Atletas & treinadores
// ────────────────────────────────────────────────────────────────────────────

model Athlete {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachId           String?
  coach             Coach?          @relation(fields: [coachId], references: [id])

  birthDate         DateTime?
  sex               Sex?
  heightCm          Float?
  weightKg          Float?
  goal              Goal?
  level             ExperienceLevel @default(INICIANTE)
  weeklyAvailability Int?           // dias por semana
  availableMinutes   Int?           // minutos por sessão
  injuryHistory      String?
  raceDate           DateTime?
  recentBestTime     String?
  status             String          @default("ativo") // ativo | risco | inativo
  adherenceRate      Float           @default(0) // 0–1
  recoveryScore      Float           @default(0) // 0–1

  parqAccepted       Boolean         @default(false)
  parqAcceptedAt     DateTime?

  metrics            Metric[]
  checkins           CheckIn[]
  performanceTests   PerformanceTest[]
  trainingPlans      TrainingPlan[]
  workoutLogs        WorkoutLog[]
  races              Race[]
  achievements       Achievement[]
  teamMemberships    TeamMember[]
  loadParams         AthleteLoadParams?
  planPurchases      PlanPurchase[]
  recoveryLogs       RecoveryLog[]

  shoes              Shoe[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([coachId])
  @@map("athletes")
}

model Coach {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential      String?   // ex.: CREF 014626-G/MG
  bio             String?
  publicBio       String?   // texto exibido na página pública da assessoria
  specialties     String[]
  slug            String?   @unique  // ex.: "ricardo-pace" → /p/ricardo-pace
  logoUrl         String?
  whatsapp        String?
  onboardingDone  String[]  @default([])  // completed step ids: ["invite","workout","plan"]

  plans             CoachPlan[]
  athletes          Athlete[]
  teams             Team[]
  trainingPlans     TrainingPlan[]
  exercises         Exercise[]
  strengthTemplates CoachStrengthTemplate[]
  runTemplates      CoachRunTemplate[]
  leads             Lead[]
  expenses          Expense[]
  zoneModels        CoachZoneModel[]
  planProducts      PlanProduct[]
  sharedTemplates   SharedWorkoutTemplate[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("coaches")
}

model Team {
  id        String       @id @default(cuid())
  name      String
  coachId   String
  coach     Coach        @relation(fields: [coachId], references: [id])
  members   TeamMember[]
  createdAt DateTime     @default(now())

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([teamId, athleteId])
  @@map("team_members")
}

// ────────────────────────────────────────────────────────────────────────────
// Periodização & planos de treino
// ────────────────────────────────────────────────────────────────────────────

enum CyclePhase {
  BASE
  CONSTRUCAO
  ESPECIFICO
  POLIMENTO
  COMPETICAO
  RECUPERACAO
}

model TrainingPlan {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coachId     String?
  coach       Coach?   @relation(fields: [coachId], references: [id])

  purchaseId  String?  @unique  // link to the PlanPurchase that originated this plan

  name        String
  goal        Goal
  raceDate    DateTime?
  macrocycle  String?  // nome/descrição do macrociclo
  phase       CyclePhase @default(BASE)
  startDate   DateTime
  endDate     DateTime

  weeks       TrainingWeek[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("training_plans")
}

model TrainingWeek {
  id           String     @id @default(cuid())
  planId       String
  plan         TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  weekNumber   Int
  mesocycle    String?
  phase        CyclePhase @default(BASE)
  startDate    DateTime
  endDate      DateTime
  targetLoad   Float?     // carga semanal planejada (TRIMP/UA)
  targetVolumeKm Float?
  released     Boolean    @default(false) // liberação semanal pelo treinador
  releasedAt   DateTime?

  workouts     Workout[]

  @@unique([planId, weekNumber])
  @@index([planId, weekNumber])
  @@map("training_weeks")
}

// ────────────────────────────────────────────────────────────────────────────
// Treinos
// ────────────────────────────────────────────────────────────────────────────

enum WorkoutType {
  RODAGEM_LEVE
  INTERVALADO_CURTO
  INTERVALADO_LONGO
  TEMPO_RUN
  FARTLEK
  PROGRESSIVO
  LONGAO
  REGENERATIVO
  SUBIDA
  TECNICA
  PROVA
  FORCA
  FUNCIONAL
  MOBILIDADE
  RECUPERACAO
}

enum WorkoutStatus {
  AGENDADO
  LIBERADO
  CONCLUIDO
  PERDIDO
  AJUSTADO
}

model Workout {
  id            String        @id @default(cuid())
  weekId        String
  week          TrainingWeek  @relation(fields: [weekId], references: [id], onDelete: Cascade)

  date          DateTime
  type          WorkoutType
  title         String
  status        WorkoutStatus @default(AGENDADO)

  objective     String?
  warmup        String?
  mainSet       String?
  cooldown      String?
  notes         String?

  structured    Boolean  @default(false)  // treino com blocos estruturados
  blocks        Json?                     // WorkoutBlock[] — ver lib/workout-blocks.ts

  targetPaceSecPerKm Int?
  targetHrZone       String?
  targetRpe          Int?
  targetDistanceKm   Float?
  targetDurationMin  Int?

  videoUrl      String?
  imageUrl      String?

  strengthWorkout StrengthWorkout?
  logs            WorkoutLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([weekId, date])
  @@map("workouts")
}

model WorkoutLog {
  id           String   @id @default(cuid())
  workoutId    String?
  workout      Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  athleteId    String
  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  // Source tracking
  source          String   @default("manual") // manual | strava | garmin | polar | coros | apple
  stravaActivityId String?  @unique

  startedAt    DateTime?
  finishedAt   DateTime?
  distanceKm   Float?
  durationSec  Int?
  avgPaceSecPerKm Int?
  avgHr        Int?
  maxHr        Int?
  cadence      Int?
  elevationGainM Float?
  calories     Int?
  gpsTrack     Json?
  splits       Json?

  rpe          Int?
  feeling      String?

  comments     WorkoutLogComment[]

  createdAt    DateTime @default(now())

  @@index([athleteId, startedAt])
  @@index([workoutId])
  @@map("workout_logs")
}

model WorkoutLogComment {
  id           String     @id @default(cuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  text         String

  createdAt    DateTime   @default(now())

  @@index([workoutLogId])
  @@map("workout_log_comments")
}

// ────────────────────────────────────────────────────────────────────────────
// Força & funcional
// ────────────────────────────────────────────────────────────────────────────

enum StrengthSplit {
  AB
  ABC
  ABCD
  ABCDE
  FULL_BODY
  UPPER_LOWER
  PERSONALIZADA
}

model StrengthWorkout {
  id        String        @id @default(cuid())
  workoutId String        @unique
  workout   Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  split     StrengthSplit @default(FULL_BODY)
  label     String?       // ex.: "Treino A — Inferior + Core"
  blocks    StrengthBlock[]

  @@map("strength_workouts")
}

model StrengthBlock {
  id                String          @id @default(cuid())
  strengthWorkoutId String
  strengthWorkout   StrengthWorkout @relation(fields: [strengthWorkoutId], references: [id], onDelete: Cascade)
  exerciseId        String
  exercise          Exercise        @relation(fields: [exerciseId], references: [id])

  order             Int
  sets              Int
  reps              String  // ex.: "10-12" ou "30s"
  load              String? // ex.: "60% 1RM" ou "peso corporal"
  restSec           Int?
  rpe               Int?
  notes             String?

  @@map("strength_blocks")
}

enum ExerciseCategory {
  FORCA
  HIPERTROFIA
  CORE
  MOBILIDADE
  PLIOMETRIA
  PREVENCAO
  GLUTEOS
  PANTURRILHAS
  JOELHO
  QUADRIL
  TORNOZELO
}

model Exercise {
  id            String           @id @default(cuid())
  coachId       String?
  coach         Coach?           @relation(fields: [coachId], references: [id])

  name          String
  category      ExerciseCategory
  description   String?
  execution     String?          // execução correta
  commonMistakes String?         // erros comuns
  musclesWorked String[]
  imageUrl      String?

  videos        ExerciseVideo[]
  blocks        StrengthBlock[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("exercises")
}

model ExerciseVideo {
  id         String   @id @default(cuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  url        String
  title      String?
  durationSec Int?

  @@map("exercise_videos")
}

// ────────────────────────────────────────────────────────────────────────────
// Testes de performance
// ────────────────────────────────────────────────────────────────────────────

enum TestType {
  COOPER
  CINCO_MINUTOS
  TRES_KM
  DOIS_MIL_E_QUATROCENTOS_M
  VAM
  RAST
  LIMIAR
}

model PerformanceTest {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  type        TestType
  date        DateTime
  distanceM   Float?
  durationSec Int?
  avgHr       Int?
  maxHr       Int?

  // resultados calculados
  vo2max      Float?
  vamKmh      Float?
  thresholdPaceSecPerKm Int?
  notes       String?

  createdAt   DateTime @default(now())

  @@index([athleteId, date])
  @@map("performance_tests")
}

// ────────────────────────────────────────────────────────────────────────────
// Check-ins & métricas
// ────────────────────────────────────────────────────────────────────────────

model CheckIn {
  id         String   @id @default(cuid())
  athleteId  String
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  date       DateTime @default(now())
  rpe        Int?     // 0-10
  pain       Int?     // 0-10
  sleep      Int?     // 0-10
  fatigue    Int?     // 0-10
  mood       Int?     // 0-10
  notes      String?

  flagged    Boolean  @default(false)
  flagReason String?

  // Hooper Index — estresse percebido (0-10); combina com sleep+fatigue+mood = score composto
  stress     Int?

  createdAt  DateTime @default(now())

  @@index([athleteId, date])
  @@map("checkins")
}

model Metric {
  id        String   @id @default(cuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  date      DateTime @default(now())
  weightKg  Float?
  bodyFatPct Float?
  restingHr Int?
  hrv       Float?
  vo2max    Float?
  notes     String?

  @@index([athleteId, date])
  @@map("metrics")
}

// ────────────────────────────────────────────────────────────────────────────
// Provas, conquistas, comunidade
// ────────────────────────────────────────────────────────────────────────────

model Race {
  id         String   @id @default(cuid())
  athleteId  String
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  name       String
  date       DateTime
  distanceKm Float
  goalTime   String?
  resultTime String?
  location   String?

  @@map("races")
}

model Achievement {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  title       String
  description String?
  icon        String?
  earnedAt    DateTime @default(now())

  @@map("achievements")
}

model FeedPost {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content   String
  imageUrl  String?
  workoutSummary Json?

  comments  FeedComment[]
  likes     FeedLike[]

  createdAt DateTime @default(now())

  @@map("feed_posts")
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@map("feed_comments")
}

model FeedLike {
  id       String   @id @default(cuid())
  postId   String
  post     FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("feed_likes")
}

// ────────────────────────────────────────────────────────────────────────────
// Notificações, dispositivos, assinaturas e pagamentos
// ────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

enum DeviceProvider {
  GARMIN
  COROS
  POLAR
  SUUNTO
  APPLE_WATCH
  GOOGLE_FIT
  STRAVA
  HEALTHKIT
}

model ConnectedDevice {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     DeviceProvider
  externalId   String?
  accessToken  String?
  refreshToken String?
  connectedAt  DateTime       @default(now())
  lastSyncAt   DateTime?

  @@unique([userId, provider])
  @@index([userId])
  @@map("connected_devices")
}

enum SubscriptionPlan {
  FREE
  ATHLETE
  COACH
  TEAM
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan   @default(FREE)
  status    SubscriptionStatus @default(TRIAL)
  startedAt DateTime           @default(now())
  renewsAt  DateTime?
  canceledAt DateTime?

  payments  Payment[]

  @@index([userId])
  @@map("subscriptions")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  amountCents    Int
  currency       String        @default("BRL")
  status         PaymentStatus @default(PENDING)
  method         String?       // pix | cartao | boleto
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  @@map("payments")
}

// ────────────────────────────────────────────────────────────────────────────
// Vouchers de desconto
// ────────────────────────────────────────────────────────────────────────────

enum VoucherType {
  PERCENT      // desconto percentual (1-100) sobre a mensalidade
  FREE_MONTHS  // número de meses grátis
}

enum VoucherAudience {
  B2C // planos de atleta
  B2B // planos de assessoria/treinador
  ALL
}

model Voucher {
  id          String          @id @default(cuid())
  code        String          @unique
  type        VoucherType
  value       Int             // percentual (1-100) ou nº de meses grátis
  audience    VoucherAudience @default(ALL)
  maxUses     Int?            // null = uso ilimitado
  usedCount   Int             @default(0)
  expiresAt   DateTime?
  active      Boolean         @default(true)
  note        String?         // descrição interna (ex.: "Black Friday 2026")

  createdById String
  createdBy   User            @relation("VouchersCreated", fields: [createdById], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("vouchers")
}

// ────────────────────────────────────────────────────────────────────────────
// Planos de venda da assessoria (o que o coach oferece para seus atletas)
// ────────────────────────────────────────────────────────────────────────────

enum PlanPeriod {
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

model CoachPlan {
  id          String     @id @default(cuid())
  coachId     String
  coach       Coach      @relation(fields: [coachId], references: [id], onDelete: Cascade)

  name        String
  description String?
  priceCents  Int                     // preço em centavos
  period      PlanPeriod @default(MENSAL)
  features    String[]
  active      Boolean    @default(true)
  highlight   Boolean    @default(false) // destaque no plano mais popular
  maxSlots    Int?                    // null = vagas ilimitadas
  usedSlots   Int        @default(0)
  sortOrder   Int        @default(0)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("coach_plans")
}

// ────────────────────────────────────────────────────────────────────────────
// Configurações financeiras da assessoria (recebimento de atletas)
// ────────────────────────────────────────────────────────────────────────────

enum ReceivingMethod {
  PIX
  PAGBANK
  MERCADOPAGO
  STRIPE
}

model BillingSettings {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dados fiscais
  razaoSocial     String?
  cpfCnpj         String?
  responsavel     String?

  // Conta de recebimento
  receivingMethod ReceivingMethod?
  pixKey          String?
  bankName        String?
  bankAgency      String?
  bankAccount     String?
  bankAccountType String?          // corrente | poupanca

  // Status de conexão com gateways externos
  pagbankConnected      Boolean @default(false)
  mercadopagoConnected  Boolean @default(false)
  stripeConnected       Boolean @default(false)

  // Módulo de cobrança automática de atletas (plano Assessoria+)
  autoChargeEnabled     Boolean @default(false)
  autoChargeDayOfMonth  Int?    @default(5)   // dia do vencimento mensal
  gracePeriodDays       Int?    @default(3)   // dias antes de notificar
  blockAfterDays        Int?    @default(15)  // dias de atraso para bloquear acesso

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("billing_settings")
}

// ────────────────────────────────────────────────────────────────────────────
// Biblioteca de equipe compartilhada
// ────────────────────────────────────────────────────────────────────────────

enum TemplateScope {
  PERSONAL
  TEAM
}

enum TemplateCategory {
  CORRIDA
  FORCA
  MOBILIDADE
  FUNCIONAL
}

model SharedWorkoutTemplate {
  id          String           @id @default(cuid())
  coachId     String
  coach       Coach            @relation(fields: [coachId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    TemplateCategory @default(CORRIDA)
  workoutType WorkoutType?
  scope       TemplateScope    @default(PERSONAL)
  tags        String[]

  objective   String?
  warmup      String?
  mainSet     String?
  cooldown    String?
  notes       String?
  structured  Boolean          @default(false)
  blocks      Json?

  targetPaceSecPerKm Int?
  targetHrZone       String?
  targetRpe          Int?
  targetDistanceKm   Float?
  targetDurationMin  Int?

  usedCount   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([coachId])
  @@index([scope])
  @@map("shared_workout_templates")
}

// ────────────────────────────────────────────────────────────────────────────
// Templates customizados dos treinadores
// ────────────────────────────────────────────────────────────────────────────

model CoachStrengthTemplate {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  name        String
  description String?
  division    String?
  targetLevel String   @default("Iniciante")
  focus       String   @default("forca")
  sessions    Json     // WorkoutTemplateSession[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("coach_strength_templates")
}

model CoachRunTemplate {
  id              String   @id @default(cuid())
  coachId         String
  coach           Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  targetLevel     String   @default("Iniciante")
  weeklyKm        Float    @default(0)
  sessionsPerWeek Int      @default(3)
  focus           String   @default("aerobico")
  sessions        Json     // RunTemplateSession[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("coach_run_templates")
}

// ────────────────────────────────────────────────────────────────────────────
// Carga de treino (CTL/ATL/TSB — modelo de Banister)
// ────────────────────────────────────────────────────────────────────────────

model AthleteLoadParams {
  id                      String   @id @default(cuid())
  athleteId               String   @unique
  athlete                 Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  // Corrida
  thresholdPaceSecPerKm   Int?     // pace de limiar em seg/km (ex: 300 = 5:00/km)

  // Ciclismo
  ftpWatts                Int?     // FTP em watts

  // Natação
  swimThresholdSecPer100m Int?     // pace de limiar em seg/100 m

  // FC (TRIMP)
  hrMax                   Int?     // FC máxima
  hrRest                  Int?     // FC repouso

  updatedAt               DateTime @updatedAt

  @@map("athlete_load_params")
}

// ────────────────────────────────────────────────────────────────────────────
// CRM de leads
// ────────────────────────────────────────────────────────────────────────────

model Lead {
  id              String   @id @default(cuid())
  coachId         String
  coach           Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  source          String   @default("quiz") // quiz | instagram | indicacao | site | evento | whatsapp
  stage           String   @default("novo") // novo | contato | proposta | negociacao | ganho | perdido
  notes           String?
  monthlyFeeCents Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([coachId, stage])
  @@map("leads")
}

// ────────────────────────────────────────────────────────────────────────────
// Modelos de zona de treino (configuração por treinador)
// ────────────────────────────────────────────────────────────────────────────

model CoachZoneModel {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name      String                       // ex: "Corrida Avançada"
  sport     String   @default("CORRIDA") // CORRIDA | CICLISMO | NATACAO | FORCA | GERAL
  method    String   @default("FC_MAXIMA") // FC_MAXIMA | LIMIAR | FTP | PACE | RPE
  zoneCount Int      @default(5)
  zones     Json     @default("[]")      // ZoneDef[] — ver lib/zone-models.ts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coach_zone_models")
}

// ────────────────────────────────────────────────────────────────────────────
// Loja de planilhas — coach publica, atleta independente compra
// ────────────────────────────────────────────────────────────────────────────

model PlanProduct {
  id            String    @id @default(cuid())
  coachId       String
  coach         Coach     @relation(fields: [coachId], references: [id], onDelete: Cascade)

  title         String
  slug          String    @unique
  description   String    @default("")
  sport         String    @default("CORRIDA") // CORRIDA | CICLISMO | NATACAO | FORCA | GERAL
  level         String    @default("Intermediário")
  durationWeeks Int       @default(12)
  weeklyHoursMin Float?
  weeklyHoursMax Float?
  goal          String    @default("PERFORMANCE")
  priceCents    Int       @default(0) // em centavos BRL
  currency      String    @default("BRL")
  coverUrl      String?
  published     Boolean   @default(false)
  featured      Boolean   @default(false)
  purchases     Int       @default(0)
  rating        Float?
  ratingCount   Int       @default(0)
  included      String[]  // bullet list of what's included
  planContent   Json?     // PlanWeek[] — semanas e treinos do plano

  planPurchases PlanPurchase[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([coachId])
  @@map("plan_products")
}

enum PlanPurchaseStatus {
  PENDING
  PAID
  REFUNDED
}

model PlanPurchase {
  id              String            @id @default(cuid())
  productId       String
  product         PlanProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  athleteId       String
  athlete         Athlete           @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  pricePaidCents  Int               @default(0)
  currency        String            @default("BRL")
  status          PlanPurchaseStatus @default(PENDING)
  stripeSessionId String?

  createdAt       DateTime          @default(now())

  @@unique([productId, athleteId])
  @@index([athleteId])
  @@map("plan_purchases")
}

// ────────────────────────────────────────────────────────────────────────────
// Histórico de recuperação (série temporal do recovery score)
// ────────────────────────────────────────────────────────────────────────────

model RecoveryLog {
  id            String   @id @default(cuid())
  athleteId     String
  athlete       Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  date          DateTime @default(now())
  score         Float    // 0–1 (calculado a partir de check-in: sono, fadiga, humor, dor)
  ctl           Float?   // CTL no momento do registro
  atl           Float?   // ATL no momento do registro
  tsb           Float?   // TSB no momento do registro

  createdAt     DateTime @default(now())

  @@index([athleteId, date])
  @@map("recovery_logs")
}

// ────────────────────────────────────────────────────────────────────────────
// Despesas da assessoria
// ────────────────────────────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  description String
  amountCents Int
  category    String   @default("outros") // software | marketing | pessoal | equipamento | fornecedor | outros
  supplier    String?
  date        DateTime @default(now())
  recurring   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@map("expenses")
}

// ────────────────────────────────────────────────────────────────────────────
// Tênis / sapatilhas do atleta
// ────────────────────────────────────────────────────────────────────────────

model Shoe {
  id            String   @id @default(cuid())
  athleteId     String
  athlete       Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  name          String
  brand         String
  model         String
  color         String   @default("blue")
  imageEmoji    String   @default("👟")
  imageUrl      String?
  kmAccumulated Float    @default(0)
  maxKm         Float    @default(700)
  active        Boolean  @default(true)
  dateAdded     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([athleteId])
  @@map("shoes")
}

model Conversation {
  id         String    @id @default(cuid())
  athleteId  String
  coachId    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   Message[]

  @@unique([athleteId, coachId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromUserId     String
  fromUser       User         @relation("MessagesSent", fields: [fromUserId], references: [id])
  content        String
  isAI           Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}
