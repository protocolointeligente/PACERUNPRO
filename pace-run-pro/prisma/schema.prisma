// ────────────────────────────────────────────────────────────────────────────
// Carga de treino (CTL/ATL/TSB — modelo de Banister)
// ────────────────────────────────────────────────────────────────────────────

model AthleteLoadParams {
  id                      String   @id @default(cuid())
  athleteId               String   @unique
  athlete                 Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  // Corrida
  thresholdPaceSecPerKm   Int?     // pace de limiar em seg/km (ex: 300 = 5:00/km)

  // Ciclismo
  ftpWatts                Int?     // FTP em watts

  // Natação
  swimThresholdSecPer100m Int?     // pace de limiar em seg/100 m

  // FC (TRIMP)
  hrMax                   Int?     // FC máxima
  hrRest                  Int?     // FC repouso

  updatedAt               DateTime @updatedAt

  @@map("athlete_load_params")
}

// ────────────────────────────────────────────────────────────────────────────
// Perfil multisport por modalidade — CSS, FTP, paces, zonas específicas
// ────────────────────────────────────────────────────────────────────────────

model AthleteSportProfile {
  id          String    @id @default(cuid())
  athleteId   String
  athlete     Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  sport       SportType // RUN | BIKE | SWIM | STRENGTH | MOBILITY | TRIATHLON | BRICK

  // ── Corrida ───────────────────────────────────────────
  thresholdPaceSecPerKm Int?  // pace limiar (seg/km)
  vdot                  Float? // VDOT de Daniels
  vamKmh                Float? // VAM em km/h
  vo2max                Float? // VO2max estimado (ml/kg/min)

  // ── Ciclismo ──────────────────────────────────────────
  ftpWatts              Int?   // FTP em watts
  ftpWattsPerKg         Float? // FTP relativo (W/kg)
  criticalPowerWatts    Int?   // Potência crítica (CP)
  wPrimeJoules          Int?   // Reserva anaeróbia W' em joules

  // ── Natação ───────────────────────────────────────────
  cssPacePer100m        Int?   // Critical Swim Speed em seg/100m
  cssMetersPerSec       Float? // CSS em m/s

  // ── FC (universal) ────────────────────────────────────
  hrMax                 Int?   // FC máxima para esta modalidade
  hrRest                Int?   // FC repouso
  hrThreshold           Int?   // FC limiar (LTHR)

  // ── Zonas personalizadas ──────────────────────────────
  zones                 Json?  // ZoneDef[] sobrescreve modelo padrão

  updatedAt             DateTime @updatedAt

  @@unique([athleteId, sport])
  @@index([athleteId])
  @@map("athlete_sport_profiles")
}

// ────────────────────────────────────────────────────────────────────────────
// CRM de leads
// ────────────────────────────────────────────────────────────────────────────

model Lead {
  id              String   @id @default(cuid())
  coachId         String
  coach           Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  source          String   @default("quiz") // quiz | instagram | indicacao | site | evento | whatsapp
  stage           String   @default("novo") // novo | contato | proposta | negociacao | ganho | perdido
  notes           String?
  monthlyFeeCents Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([coachId, stage])
  @@map("leads")
}

// ────────────────────────────────────────────────────────────────────────────
// Modelos de zona de treino (configuração por treinador)
// ────────────────────────────────────────────────────────────────────────────

model CoachZoneModel {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name      String                       // ex: "Corrida Avançada"
  sport     String   @default("CORRIDA") // CORRIDA | CICLISMO | NATACAO | FORCA | GERAL
  method    String   @default("FC_MAXIMA") // FC_MAXIMA | LIMIAR | FTP | PACE | RPE
  zoneCount Int      @default(5)
  zones     Json     @default("[]")      // ZoneDef[] — ver lib/zone-models.ts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coach_zone_models")
}

// ────────────────────────────────────────────────────────────────────────────
// Loja de planilhas — coach publica, atleta independente compra
// ────────────────────────────────────────────────────────────────────────────

model PlanProduct {
  id            String    @id @default(cuid())
  coachId       String?
  coach         Coach?    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  title         String
  slug          String    @unique
  description   String    @default("")
  sport         String    @default("CORRIDA") // CORRIDA | CICLISMO | NATACAO | FORCA | GERAL
  level         String    @default("Intermediário")
  durationWeeks Int       @default(12)
  weeklyHoursMin Float?
  weeklyHoursMax Float?
  goal          String    @default("PERFORMANCE")
  priceCents    Int       @default(0) // em centavos BRL
  currency      String    @default("BRL")
  coverUrl      String?
  published     Boolean   @default(false)
  featured      Boolean   @default(false)
  purchases     Int       @default(0)
  rating        Float?
  ratingCount   Int       @default(0)
  included      String[]  // bullet list of what's included
  planContent   Json?     // PlanWeek[] — semanas e treinos do plano

  planPurchases PlanPurchase[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([coachId])
  @@map("plan_products")
}

enum PlanPurchaseStatus {
  PENDING
  PAID
  REFUNDED
}

model PlanPurchase {
  id              String            @id @default(cuid())
  productId       String
  product         PlanProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  athleteId       String
  athlete         Athlete           @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  pricePaidCents  Int               @default(0)
  currency        String            @default("BRL")
  status          PlanPurchaseStatus @default(PENDING)
  stripeSessionId String?

  createdAt       DateTime          @default(now())

  @@unique([productId, athleteId])
  @@index([athleteId])
  @@map("plan_purchases")
}

// ────────────────────────────────────────────────────────────────────────────
// Histórico de recuperação (série temporal do recovery score)
// ────────────────────────────────────────────────────────────────────────────

model RecoveryLog {
  id            String   @id @default(cuid())
  athleteId     String
  athlete       Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  date          DateTime @default(now())
  score         Float    // 0–1 (calculado a partir de check-in: sono, fadiga, humor, dor)
  ctl           Float?   // CTL no momento do registro
  atl           Float?   // ATL no momento do registro
  tsb           Float?   // TSB no momento do registro

  createdAt     DateTime @default(now())

  @@index([athleteId, date])
  @@map("recovery_logs")
}

// ────────────────────────────────────────────────────────────────────────────
// Despesas da assessoria
// ────────────────────────────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  description String
  amountCents Int
  category    String   @default("outros") // software | marketing | pessoal | equipamento | fornecedor | outros
  supplier    String?
  date        DateTime @default(now())
  recurring   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@map("expenses")
}

// ────────────────────────────────────────────────────────────────────────────
// Tênis / sapatilhas do atleta
// ────────────────────────────────────────────────────────────────────────────

model Shoe {
