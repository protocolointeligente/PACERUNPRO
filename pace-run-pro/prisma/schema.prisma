// ────────────────────────────────────────────────────────────────────────────
// Marketplace Fase 1 — Ecossistema de produtos e serviços
// ────────────────────────────────────────────────────────────────────────────

model MarketplaceStore {
  id            String   @id @default(cuid())
  coachId       String   @unique
  coach         Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)

  name          String
  slug          String   @unique
  description   String?
  logoUrl       String?
  bannerUrl     String?
  primaryColor  String   @default("#C6F24E")
  instagramUrl  String?
  whatsapp      String?

  commissionPct Float    @default(0.15)
  isActive      Boolean  @default(true)
  stripeAccountId String?  // Stripe Connect account

  products      MarketplaceProduct[]
  coupons       MarketplaceCoupon[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("marketplace_stores")
}

enum MarketplaceProductType {
  PLANILHA
  EBOOK
  CURSO
  EVENTO
  CONSULTORIA
  AVALIACAO
  TESTE
  ASSINATURA
  TREINAMENTO
}

enum MarketplaceOrderStatus {
  PENDING
  PAID
  PROCESSING
  FULFILLED
  CANCELLED
  REFUNDED
}

model MarketplaceProduct {
  id          String   @id @default(cuid())
  storeId     String?
  store       MarketplaceStore? @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coachId     String?
  coach       Coach?   @relation(fields: [coachId], references: [id], onDelete: Cascade)

  type        MarketplaceProductType @default(PLANILHA)
  title       String
  slug        String   @unique
  description String   @default("")
  coverUrl    String?

  priceCents  Int      @default(0)
  currency    String   @default("BRL")

  durationWeeks Int?
  level         String?
  sport         String?
  format        String?  // video | ao-vivo | gravado
  eventDate     DateTime?
  maxParticipants Int?
  deliveryDays  Int?

  included      String[]
  content       Json?
  fileUrl       String?

  published     Boolean  @default(false)
  featured      Boolean  @default(false)
  purchases     Int      @default(0)
  rating        Float?
  ratingCount   Int      @default(0)

  commissionPct Float?

  orderItems         MarketplaceOrderItem[]
  reviews            MarketplaceReview[]
  courseModules      CourseModule[]
  eventRegistrations EventRegistration[]
  appointments       Appointment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId])
  @@index([coachId])
  @@index([type, published])
  @@map("marketplace_products")
}

model MarketplaceOrder {
  id              String   @id @default(cuid())
  athleteId       String
  athlete         Athlete  @relation(fields: [athleteId], references: [id])

  totalCents      Int
  currency        String   @default("BRL")
  status          MarketplaceOrderStatus @default(PENDING)

  stripeSessionId String?
  pagbankOrderId  String?
  notes           String?

  couponId        String?
  coupon          MarketplaceCoupon? @relation(fields: [couponId], references: [id])
  discountCents   Int?

  items           MarketplaceOrderItem[]
  commissions     MarketplaceCommission[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([athleteId])
  @@map("marketplace_orders")
}

model MarketplaceOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     MarketplaceProduct @relation(fields: [productId], references: [id])

  priceCents  Int
  quantity    Int    @default(1)
  status      MarketplaceOrderStatus @default(PENDING)

  fulfilledAt DateTime?
  fileUrl     String?

  @@index([orderId])
  @@index([productId])
  @@map("marketplace_order_items")
}

model MarketplaceCommission {
  id              String   @id @default(cuid())
  orderId         String
  order           MarketplaceOrder @relation(fields: [orderId], references: [id])
  coachId         String?
  coach           Coach?   @relation(fields: [coachId], references: [id])

  grossCents      Int
  commissionPct   Float
  commissionCents Int
  netCents        Int

  paidOut     Boolean  @default(false)
  paidAt      DateTime?
  payoutId    String?
  payout      MarketplacePayout? @relation(fields: [payoutId], references: [id])

  createdAt   DateTime @default(now())

  @@index([coachId])
  @@index([orderId])
  @@map("marketplace_commissions")
}

model MarketplacePayout {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id])

  amountCents Int
  currency    String   @default("BRL")

  status      String   @default("PENDING")
  method      String   @default("PIX")
  pixKey      String?
  transferId  String?

  commissions MarketplaceCommission[]

  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@index([coachId])
  @@map("marketplace_payouts")
}

model MarketplaceReview {
  id          String   @id @default(cuid())
  productId   String
  product     MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id])

  rating      Int
  comment     String?

  createdAt   DateTime @default(now())

  @@unique([productId, athleteId])
  @@map("marketplace_reviews")
}

model MarketplaceConfig {
  id                  String   @id @default(cuid())
  defaultCommissionPct Float    @default(0.15)
  categoryConfig      Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("marketplace_config")
}

model MarketplaceCoupon {
  id              String   @id @default(cuid())
  code            String   @unique
  storeId         String?
  store           MarketplaceStore? @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coachId         String?
  coach           Coach?   @relation(fields: [coachId], references: [id], onDelete: Cascade)

  discountPct     Float?   // 0.0–1.0, e.g. 0.20 = 20% off
  discountCents   Int?     // fixed amount off in cents
  minOrderCents   Int?     // minimum order value to apply coupon
  maxUses         Int?     // null = unlimited
  usedCount       Int      @default(0)
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  description     String?

  orders          MarketplaceOrder[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([coachId])
  @@map("marketplace_coupons")
}

// ────────────────────────────────────────────────────────────────────────────
// Fase 2 — Cursos, Eventos, Agenda, Desafios
// ────────────────────────────────────────────────────────────────────────────

model CourseModule {
  id        String   @id @default(cuid())
  productId String
  product   MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  title     String
  position  Int      @default(0)
  lessons   CourseLesson[]
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("course_modules")
}

model CourseLesson {
  id          String   @id @default(cuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  videoUrl    String?
  duration    Int?     // seconds
  position    Int      @default(0)
  isPreview   Boolean  @default(false)
  content     String?
  createdAt   DateTime @default(now())
  progress    CourseLessonProgress[]

  @@index([moduleId])
  @@map("course_lessons")
}

model CourseLessonProgress {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id])
  completedAt DateTime @default(now())

  @@unique([lessonId, athleteId])
  @@map("course_lesson_progress")
}

model EventRegistration {
  id          String   @id @default(cuid())
  productId   String
  product     MarketplaceProduct @relation(fields: [productId], references: [id])
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id])
  orderId     String?
  status      String   @default("CONFIRMED")
  registeredAt DateTime @default(now())

  @@unique([productId, athleteId])
  @@index([productId])
  @@map("event_registrations")
}

model CoachAvailability {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      // 0=Dom ... 6=Sab
  startTime   String   // "09:00"
  endTime     String   // "18:00"
  slotMinutes Int      @default(60)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([coachId])
  @@map("coach_availability")
}

model Appointment {
  id           String   @id @default(cuid())
  coachId      String
  coach        Coach    @relation(fields: [coachId], references: [id])
  athleteId    String
  athlete      Athlete  @relation(fields: [athleteId], references: [id])
  productId    String?
  product      MarketplaceProduct? @relation(fields: [productId], references: [id])
  scheduledAt  DateTime
  durationMin  Int      @default(60)
  status       String   @default("PENDING")
  notes        String?
  meetUrl      String?
  athleteNotes String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([coachId])
  @@index([athleteId])
  @@map("appointments")
}

model Challenge {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  title       String
  description String
  type        String   @default("DISTANCIA")
  targetValue Float?
  targetUnit  String?
  sport       String   @default("CORRIDA")
  startDate   DateTime
  endDate     DateTime
  isPublic    Boolean  @default(false)
  bannerUrl   String?
  participants ChallengeParticipant[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([coachId])
  @@map("challenges")
}

model ChallengeParticipant {
  id          String   @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id])
  progress    Float    @default(0)
  completedAt DateTime?
  joinedAt    DateTime @default(now())

  @@unique([challengeId, athleteId])
  @@index([challengeId])
  @@map("challenge_participants")
}

model DailyLoad {
  id            String   @id @default(cuid())
  athleteId     String
  athlete       Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date

  tss           Float    @default(0)

  // Banister CTL/ATL/TSB
  ctl           Float    @default(0)
  atl           Float    @default(0)
  tsb           Float    @default(0)

  // EWMA (Williams et al., 2017)
  ewmaAcute     Float    @default(0)
  ewmaChronic   Float    @default(0)
  ewmaRatio     Float    @default(1)

  // Rolling windows
  weeklyLoad    Float    @default(0)
  monthlyLoad   Float    @default(0)

  // ACWR (fixed window)
  acwr          Float?

  // Tendency & alerts
  trend         String?  // "rising" | "stable" | "declining"
  form          String?  // FormStatus

  computedAt    DateTime @default(now())

  @@unique([athleteId, date])
  @@index([athleteId, date])
  @@map("daily_loads")
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  MARKETING_EMAILS
  DATA_PROCESSING
}

model DataConsentRecord {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ConsentType
  granted   Boolean     @default(true)
  ipAddress String?
  userAgent String?
  version   String?
  revokedAt DateTime?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@map("data_consent_records")
}
