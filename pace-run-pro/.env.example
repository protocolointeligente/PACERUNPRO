# Runtime
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Payments — PagBank
PAGBANK_ENV=sandbox
PAGBANK_TOKEN=
PAGBANK_WEBHOOK_TOKEN=
PAGBANK_PLATFORM_ACCOUNT_ID=
PAGBANK_RETURN_URL=http://localhost:3000/checkout/sucesso

# Integrations
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/integrations/strava/callback

# Email / observability (optional)
RESEND_API_KEY=
EMAIL_FROM=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Public app URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=10
